# SalesTrendsDashboard — Environment Variables Template
# -------------------------------------------------------
# Copy this to .env for local development.
# NEVER commit .env to git. Set these in the Zoho Catalyst
# console under: Functions → salestrends → Environment Variables

# ── GitHub (primary data source for Catalyst) ──
# Personal Access Token with repo:read scope on the data repo
GITHUB_TOKEN=your_github_pat_here
# Full repo path: owner/reponame
GITHUB_REPO=shubhkrishna19/salestrendsdashboard
# Filename inside the repo (root level)
DATA_FILE=data.xlsx
# Excel sheet name containing the sales data
SHEET_NAME=Final Sale Data

# ── Zoho (only if using Zoho Creator/Analytics as data source in future) ──
# These are NOT needed for the current GitHub-based data loading.
# If added later, set via Catalyst environment variables ONLY — never hardcode.
# ZOHO_REFRESH_TOKEN=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
